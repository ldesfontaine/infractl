services:
  socket-proxy:
    image: {{ traefik_socket_proxy_image }}
    environment:
      CONTAINERS: 1
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks: [docker-api]
    restart: unless-stopped

  authelia:
    image: {{ authelia_image }}
    user: "{{ authelia_uid }}:{{ authelia_uid }}"
    security_opt: [no-new-privileges:true]
    cap_drop: [ALL]
    read_only: true
    environment:
      AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET_FILE: /secrets/jwt_secret
      AUTHELIA_SESSION_SECRET_FILE: /secrets/session_secret
      AUTHELIA_STORAGE_ENCRYPTION_KEY_FILE: /secrets/storage_encryption_key
    volumes:
      - ./authelia:/config
      - ./secrets/authelia:/secrets:ro
    networks: [proxy]
    labels:
      - traefik.enable=true
      - traefik.http.routers.authelia.rule=Host(`auth.{{ lab_domain }}`)
      - traefik.http.routers.authelia.entrypoints=websecure
    # Healthcheck embarqué inutilisable : il lit /app/.healthcheck.env, écrit par
    # Authelia au démarrage — impossible avec read_only. D'où disable_healthcheck
    # côté config + ce healthcheck à nous.
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:9091/api/health"]
      interval: 30s
      timeout: 5s
      retries: 3
    restart: unless-stopped

  traefik:
    image: {{ traefik_image }}
    user: "65532:65532"
    security_opt: [no-new-privileges:true]
    cap_drop: [ALL]
    read_only: true
    depends_on: [socket-proxy]
    ports:
      - "${BIND_IP}:${HTTP_PORT}:8080"
      - "${BIND_IP}:${HTTPS_PORT}:8443"
    volumes:
      - ./traefik/traefik.yml:/etc/traefik/traefik.yml:ro
      - ./traefik/dynamic:/etc/traefik/dynamic:ro
      - ./traefik/acme:/acme
      - ./traefik/logs:/var/log/traefik
      - ./traefik/plugins:/plugins-storage
      - ./secrets/crowdsec.key:/etc/traefik/crowdsec.key:ro
    env_file:
      - secrets/cloudflare.env
    extra_hosts:
      - host.docker.internal:host-gateway
    networks: [docker-api, proxy]
    restart: unless-stopped

  crowdsec:
    image: {{ crowdsec_image }}
    security_opt: [no-new-privileges:true]
    cap_drop: [ALL]
    # read_only/user non-root : non supportés par l'image — l'entrypoint
    # réécrit /etc/crowdsec/config.yaml à chaque démarrage et l'init copie
    # des fichiers 0600 root (issue crowdsec#3303). Écart documenté (3-B).
    environment:
      COLLECTIONS: "{{ crowdsec_collections | join(' ') }}"
{% if not crowdsec_online_api %}
      DISABLE_ONLINE_API: "true"
{% endif %}
    env_file:
      - secrets/crowdsec.env
    volumes:
      - ./crowdsec/config:/etc/crowdsec
      - ./crowdsec/data:/var/lib/crowdsec/data
      - ./traefik/logs:/var/log/traefik:ro
    networks: [proxy]
    healthcheck:
      test: ["CMD", "cscli", "lapi", "status"]
      interval: 30s
      timeout: 5s
      retries: 3
    restart: unless-stopped

networks:
  docker-api: { internal: true }
  proxy: {}
