api:
  dashboard: true

experimental:
  plugins:
    bouncer:
      moduleName: github.com/maxlerebourg/crowdsec-bouncer-traefik-plugin
      version: "{{ traefik_crowdsec_plugin_version }}"

providers:
  docker:
    endpoint: "tcp://socket-proxy:2375"
    exposedByDefault: false
  file:
    directory: /etc/traefik/dynamic
    watch: true

entryPoints:
  web:
    address: ":8080"
    http:
      redirections:
        entryPoint: { to: ":{{ traefik_https_port }}", scheme: https }
  websecure:
    address: ":8443"
    http:
      middlewares:
        # Ordre significatif : réputation avant identité.
        - crowdsec@file
        - authelia@file
      tls:
        certResolver: le
        domains:
          - main: "{{ lab_domain }}"
            sans: ["*.{{ lab_domain }}"]

certificatesResolvers:
  le:
    acme:
      email: "{{ acme_email }}"
      storage: /acme/acme.json
      caServer: "{{ traefik_acme_ca_server }}"
      dnsChallenge:
        provider: "{{ traefik_acme_dns_provider }}"
        resolvers: ["1.1.1.1:53"]

log:
  level: INFO

accessLog:
  filePath: /var/log/traefik/access.log
  format: json
